# StreamLens — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Never commit .env to git (it's in .gitignore).

# ── Kafka ──────────────────────────────────────────────────────────────────────
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC=github-events
KAFKA_GROUP_ID=streamlens-events-consumer

# ── GitHub API ─────────────────────────────────────────────────────────────────
# Without a token: 60 requests/hour (fine for dev)
# With a token:  5,000 requests/hour
# Generate at: https://github.com/settings/tokens (no scopes needed for public events)
# GITHUB_TOKEN=ghp_your_token_here

POLL_INTERVAL=5

# ── Consumer / Storage ─────────────────────────────────────────────────────────
# Flush a new Parquet file when EITHER condition is met:
BATCH_SIZE=100
FLUSH_INTERVAL_SECONDS=30

DATA_DIR=data/events

# Events older than this many hours go to data/events/date=late/ instead of
# their correct date partition. Increase if your consumer restarts are long.
LATE_EVENT_THRESHOLD_HOURS=24

# ── Dashboard ──────────────────────────────────────────────────────────────────
REFRESH_INTERVAL=4
STATS_WINDOW_MINUTES=60
TOP_REPOS_LIMIT=8
FEED_LIMIT=20

# ── Stream scope ───────────────────────────────────────────────────────────────
# global = the whole public GitHub firehose (original Day 1-11 behavior)
# repo   = only STREAM_REPO's events — pairs the event stream with the AI
#          layer's CI signal and knowledge base (one coherent source)
STREAM_MODE=repo
# Defaults to KB_REPO when unset:
# STREAM_REPO=kubernetes/kubernetes

# Anomaly rules only consider this repo's events (unset = whole stream).
# Should match STREAM_REPO / KB_REPO in repo mode.
ANOMALY_REPO=kubernetes/kubernetes

# ── AI Diagnostic Layer (FastAPI + RAG + Haiku) ────────────────────────────────
# Claude API — required for LLM diagnoses (GET /diagnose, POST /query).
# Without it the API returns a clearly-marked fallback instead of a diagnosis.
# ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Voyage AI — required for real embeddings; without it a deterministic
# hash-based stub is used (demo still runs, retrieval quality is meaningless)
# VOYAGE_API_KEY=pa-your-key-here
EMBEDDING_MODEL=voyage-3-lite

# Knowledge base: which repo's closed issues/PRs to mine (labels + reverts)
KB_REPO=kubernetes/kubernetes
KB_MAX_ITEMS=300
KB_DIR=data/knowledge

# CI stability signal: GitHub Actions workflow runs for this repo
# (defaults to KB_REPO if unset)
# CI_REPO=
CI_DIR=data/ci_runs

# Anomaly store
ANOMALY_DIR=data/anomalies

# FastAPI service
API_HOST=127.0.0.1
API_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000

# ── Compaction ─────────────────────────────────────────────────────────────────
# Run compaction manually: PYTHONPATH=src python src/storage/compaction.py
# Or add to cron: 0 1 * * * cd /path/to/streamlens && PYTHONPATH=src python src/storage/compaction.py
